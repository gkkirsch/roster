#!/usr/bin/env bash
# agent-browser — roster wrapper.
#
# Forces every invocation through the per-space CDP port so an agent can't
# accidentally launch a separate browser or talk to the wrong one. Strips
# user-supplied --cdp / --profile / --session / --executable-path /
# --auto-connect so they can't override us. Blocks subcommands that would
# escape isolation (`connect`, `dashboard`, `doctor`).
#
# Looks up the real `agent-browser` binary on PATH (skipping ourselves);
# falls back to `npx -y agent-browser` if nothing is installed globally.
set -euo pipefail

# Resolve the real agent-browser binary. roster's installBrowserWrapper
# wrote its path to a sidecar at install time (so we don't have to
# discover it dynamically and risk recursing into our own symlink).
# Resolve $0 through any symlinks first — when invoked via
# ~/.local/bin/agent-browser the sidecar lives next to the canonical
# script, not next to the symlink.
self_resolved=$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys;print(os.path.realpath(sys.argv[1]))" "$0")
self_dir=$(cd -- "$(dirname -- "$self_resolved")" && pwd)
real=""
sidecar="$self_dir/.agent-browser-real"
if [[ -f "$sidecar" ]]; then
  real=$(< "$sidecar")
fi
if [[ ! -x "$real" ]]; then
  echo "agent-browser: real binary not found (sidecar at $sidecar). Re-run \`roster spawn\` or reinstall agent-browser." >&2
  exit 2
fi

# Outside a roster space (no AGENT_BROWSER_CDP), pass through unchanged
# so user's main shell sees vanilla agent-browser. Only roster orchs
# get the enforced --cdp + blocked subcommands.
if [[ -z "${AGENT_BROWSER_CDP:-}" ]]; then
  exec "$real" "$@"
fi

case "${1:-}" in
  connect|dashboard|doctor)
    echo "agent-browser: subcommand '$1' is blocked inside roster spaces (would launch / probe a separate browser)." >&2
    exit 2
    ;;
esac

filtered=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cdp|--profile|--session|--executable-path)
      shift
      [[ $# -gt 0 ]] && shift
      ;;
    --cdp=*|--profile=*|--session=*|--executable-path=*)
      shift
      ;;
    --auto-connect)
      shift
      ;;
    *)
      filtered+=("$1")
      shift
      ;;
  esac
done

# agent-browser's --cdp is attach-only: if the port is dead, it falls
# back to an internal "auto-launch" that hardcodes port 9222 and fails
# (or worse, would talk to the user's main browser). So before we
# exec, make sure Chrome is alive on OUR per-orch port. If not, launch
# it ourselves with the per-orch profile and port — the same args
# fleetview's globe button uses.
chrome_alive() {
  curl -sf -m 1 -o /dev/null "http://127.0.0.1:${AGENT_BROWSER_CDP}/json/version" 2>/dev/null
}

# A daemon may already exist for this session from a prior run, holding a
# reference to a Chrome that has since been closed. When that happens
# agent-browser ignores --cdp and tries to use the dead browser. Detect
# (Chrome dead + daemon alive) and kill the daemon so it respawns clean.
# AGENT_BROWSER_SESSION defaults to "default" inside agent-browser, so we
# match that fallback when env doesn't override it.
session_name="${AGENT_BROWSER_SESSION:-default}"
session_dir="$HOME/.agent-browser"
session_pid_file="$session_dir/${session_name}.pid"
if [[ -f "$session_pid_file" ]] && ! chrome_alive; then
  daemon_pid=$(cat "$session_pid_file" 2>/dev/null || true)
  if [[ -n "$daemon_pid" ]] && kill -0 "$daemon_pid" 2>/dev/null; then
    kill "$daemon_pid" 2>/dev/null || true
    for _ in $(seq 1 20); do
      kill -0 "$daemon_pid" 2>/dev/null || break
      sleep 0.1
    done
  fi
  rm -f "$session_dir/${session_name}".{pid,sock,stream,version} 2>/dev/null || true
fi

if ! chrome_alive; then
  if [[ -z "${AGENT_BROWSER_PROFILE:-}" ]]; then
    echo "agent-browser: AGENT_BROWSER_PROFILE not set — can't launch isolated Chrome on port ${AGENT_BROWSER_CDP}. Spawn this agent through roster so the per-orch profile is provisioned." >&2
    exit 2
  fi
  open -na "Google Chrome" --args \
    --user-data-dir="$AGENT_BROWSER_PROFILE" \
    --remote-debugging-port="$AGENT_BROWSER_CDP" \
    --no-first-run \
    --no-default-browser-check \
    --window-size=1280,800 \
    about:blank >/dev/null 2>&1 || true
  # Wait up to ~6s for Chrome to bind the port. Mirrors fleetview's
  # 40 × 150ms poll in launchChrome.
  for _ in $(seq 1 40); do
    if chrome_alive; then
      break
    fi
    sleep 0.15
  done
  if ! chrome_alive; then
    echo "agent-browser: Chrome failed to bind 127.0.0.1:${AGENT_BROWSER_CDP} within 6s." >&2
    echo "agent-browser:   profile: ${AGENT_BROWSER_PROFILE}" >&2
    echo "agent-browser:   try: \`roster doctor\` to inspect Chrome / daemon state" >&2
    exit 2
  fi
fi

exec "$real" --cdp "$AGENT_BROWSER_CDP" "${filtered[@]}"
